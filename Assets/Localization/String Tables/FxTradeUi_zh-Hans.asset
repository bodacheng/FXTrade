    m_Localized: "\u5F53\u524D\u51C0\u5EFA\u7389\u6570\u91CF\u4E0D\u4E3A0\u65F6\uFF0C\u8BF7\u586B\u5199USD/JPY\u5EFA\u4ED3\u4EF7\uFF1A\u6570\u91CF\u6B63\u6570=\u4E70\u5165\uFF0C\u8D1F\u6570=\u5356\u51FA\u3002"
